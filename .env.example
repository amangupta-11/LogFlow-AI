# AI Log Collector & Generator - Environment Configuration Example
# Copy this file to '.env' and fill in your custom credentials.

# ==========================================
# 1. LLM Provider API Keys (At least one is required)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==========================================
# 2. Gmail/SMTP Notification Credentials
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
EMAIL_TO=recipient_email_address@gmail.com

# ==========================================
# 3. Optional Database Configuration
# ==========================================
# By default, the application runs on SQLite. If DATABASE_URL is provided,
# db_manager will attempt to connect to a PostgreSQL database.
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# SQLITE_DB_PATH=jobs.db
# REPO_DB_PATH=validated_logs.db

# ==========================================
# 4. Optional Autonomous Agent Ingestion Tuning
# ==========================================
MAX_TECHNOLOGIES_PER_CYCLE=5
MAX_QUERIES_PER_TECHNOLOGY=5
MAX_URLS_PER_TECHNOLOGY=5
MAX_RUNTIME_PER_JOB=900
DISABLE_STRICT_VALIDATION=false
SLACK_WEBHOOK_URL=
